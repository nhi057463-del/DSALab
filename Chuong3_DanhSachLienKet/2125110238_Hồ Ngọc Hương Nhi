CON TRỎ CƠ BẢN:
+Con trỏ là biến dùng để lưu địa chỉ của một biến khác.
  - p → chứa địa chỉ
  - *p → lấy giá trị tại địa chỉ đó
  - &a → lấy địa chỉ của biến a

CON TRỎ CAO CẤP(MẢNG)
+Con trỏ dùng để duyệt và truy cập các phần tử của mảng
+Tên mảng chính là địa chỉ phần tử đầu tiên:
     int arr[] = {1, 2, 3};
     int *p = arr;
  - p trỏ tới arr[0]
  - Có thể dùng con trỏ để duyệt mảng

CON TRỎ ĐỘNG
+Con trỏ dùng để cấp phát bộ nhớ trong lúc chương trình đang chạy
+Khi bạn chưa biết trước số lượng phần tử → dùng con trỏ động
  - new int[n] → tạo mảng trong bộ nhớ động
  - p → trỏ tới vùng nhớ đó
  - delete[] p → trả lại bộ nhớ

#include <iostream>
using namespace std;

// Hàm swap dùng con trỏ (cao cấp)
void swapValues(int* x, int* y) {
    int temp = *x;
    *x = *y;
    *y = temp;
}

int main() {
    cout << "=== 1. Con tro co ban ===" << endl;

    int a = 10;
    int* p = &a;

    cout << "Gia tri a: " << a << endl;
    cout << "Dia chi a: " << &a << endl;
    cout << "Gia tri p (dia chi a): " << p << endl;
    cout << "Gia tri *p: " << *p << endl;

    cout << "\n=== 2. Con tro cao cap (mang) ===" << endl;

    int arr[] = { 1, 2, 3, 4, 5 };
    int* ptr = arr;

    for (int i = 0; i < 5; i++) {
        cout << "arr[" << i << "] = " << *(ptr + i) << endl;
    }

    cout << "\nHoan doi 2 bien bang con tro:" << endl;
    int x = 5, y = 10;

    swapValues(&x, &y);

    cout << "x = " << x << ", y = " << y << endl;

    cout << "\n=== 3. Con tro dong ===" << endl;

    int n;
    cout << "Nhap so phan tu: ";
    cin >> n;

    int* dynamicArr = new int[n]; // cap phat dong

    // Nhap mang
    for (int i = 0; i < n; i++) {
        cout << "a[" << i << "] = ";
        cin >> dynamicArr[i];
    }

    // In mang
    cout << "Mang vua nhap: ";
    for (int i = 0; i < n; i++) {
        cout << *(dynamicArr + i) << " ";
    }

    // Giai phong bo nho
    delete[] dynamicArr;

    cout << endl;
    return 0;
}
kết quả:
=== 1. Con tro co ban ===
Gia tri a: 10
Dia chi a: 000000766B3CF404
Gia tri p (dia chi a): 000000766B3CF404
Gia tri *p: 10

=== 2. Con tro cao cap (mang) ===
arr[0] = 1
arr[1] = 2
arr[2] = 3
arr[3] = 4
arr[4] = 5

Hoan doi 2 bien bang con tro:
x = 10, y = 5

=== 3. Con tro dong ===
Nhap so phan tu: 3
a[0] = 5
a[1] = 3
a[2] = 6
Mang vua nhap: 5 3 6
